# API Configuration
API_URL=http://localhost:1337/api
BACK_URL=http://localhost:1337

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
YANDEX_APIKEY_MAP=your_yandex_map_api_key

# SMTP Configuration for Email Sending
MAIL_DRIVER=smtp
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=your-email@yandex.ru
SMTP_PASSWORD=your-app-password
MAIL_FROM_NAME=УПК МЯСО
MAIL_FROM_ADDRESS=your-email@yandex.ru

# Strapi API Token for creating bids without user permissions
STRAPI_API_TOKEN=your-strapi-api-token
